# KH-Viral Agent - Free API Configuration
# All APIs configured for FREE tier
# No payment required!

# ============================================
# 1. GOOGLE NEWS API (FREE)
# ============================================
# Get it FREE at: https://newsapi.org
# Steps:
# 1. Go to https://newsapi.org
# 2. Click "Get API Key"
# 3. Sign up (free)
# 4. Check email
# 5. Copy API key
GOOGLE_NEWS_API_KEY=demo

# ============================================
# 2. REDDIT API (FREE)
# ============================================
# Get it FREE at: https://reddit.com/prefs/apps
# Steps:
# 1. Go to https://reddit.com/login
# 2. Login (or create account)
# 3. Go to https://reddit.com/prefs/apps
# 4. Click "Create app" at bottom
# 5. Fill: Name=KH-Viral, Type=Script
# 6. Copy Client ID and Client Secret
REDDIT_CLIENT_ID=demo
REDDIT_CLIENT_SECRET=demo
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ============================================
# 3. TWITTER/X API (FREE - Basic Tier)
# ============================================
# Get it FREE at: https://developer.twitter.com
# Steps:
# 1. Go to https://developer.twitter.com
# 2. Sign in with Twitter
# 3. Click "Create an app"
# 4. Fill details (Name=KH-Viral, Use Case=News)
# 5. Go to "Keys & Tokens"
# 6. Copy Bearer Token
TWITTER_BEARER_TOKEN=demo

# ============================================
# 4. YOUTUBE API (FREE - 12 units/day)
# ============================================
# Get it FREE at: https://console.cloud.google.com
# Steps:
# 1. Go to https://console.cloud.google.com
# 2. Create new project
# 3. Search "YouTube Data API v3"
# 4. Click "Enable"
# 5. Go to "Credentials"
# 6. Create API Key
# 7. Copy it
YOUTUBE_API_KEY=demo

# ============================================
# 5. OPENAI API (PAID - $5 free credit)
# ============================================
# Get it at: https://platform.openai.com/api-keys
# Free $5 credit for new users!
# Steps:
# 1. Go to https://platform.openai.com/api-keys
# 2. Sign up
# 3. Create API key
# 4. Copy it
# Note: Uses paid model but $5 free = enough for testing
OPENAI_API_KEY=sk-demo

# ============================================
# 6. INSTAGRAM API (FREE - Basic)
# ============================================
# Get it FREE at: https://developers.facebook.com
# Note: Requires Facebook Developer account
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# ============================================
# APP SETTINGS
# ============================================
DEBUG=True
ENVIRONMENT=development
LOG_LEVEL=INFO

# ============================================
# IMPORTANT NOTES:
# ============================================
# - This .env file should NOT be committed to GitHub (it's in .gitignore)
# - Keep your API keys PRIVATE - don't share them
# - Replace 'demo' with your actual API keys
# - Most APIs have FREE tiers
# - OpenAI has $5 free credit
# - Never expose this file publicly
